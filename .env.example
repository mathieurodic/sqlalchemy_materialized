# Used by optional LLM integration tests.
#
# Copy this file to `.env` and fill in real values to enable:
#
#   pytest -q -k llm_integration
#
# NOTE: `.env` is ignored by git.

ETL_DECORATORS_TESTS_LLM_MODEL="openai/gpt-4o-mini"
ETL_DECORATORS_TESTS_LLM_API_KEY=""

# Used by optional Redis integration tests.
#
# Enable with:
#
#   pytest -q -k redis

ETL_DECORATORS_TESTS_REDIS_URL="redis://localhost:6379/0"
